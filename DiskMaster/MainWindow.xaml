<Window x:Class="DiskMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DiskMaster"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="DiskMaster" Height="620" Width="450" Icon="/hard-drive.png" ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Image Source="/clean.png" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Top" Width="40" Height="40"/>
            <Label Content="Utiliser DiskMaster pour libérer de l'espace disque sur (C:)." FontSize="12" FontWeight="Normal" Margin="60,10,10,10" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        </Grid>
        <StackPanel Grid.Row="1">
            <Label Margin="20 0" Content="Fichiers à supprimer:"></Label>
            <ListView Height="150" Margin="20 0" Name="ldb">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Nom" DisplayMemberBinding="{Binding Nom}" Width="230"/>
                        <GridViewColumn Header="Taille" DisplayMemberBinding="{Binding Taille}"/>
                    </GridView>
                </ListView.View>
            </ListView>
            <Label  x:Name="espace" Margin="20 0" Content="Espace disque libéré: 0 Mo"></Label>
            <Label Margin="20 0" Content="Description"></Label>
            <TextBlock Margin="20 0" TextWrapping="Wrap" Text="DiskMaster est un outil de nettoyage de disque qui vous aide à libérer de l'espace sur votre disque dur en supprimant les fichiers inutiles et temporaires. Il analyse votre disque dur pour identifier les fichiers qui peuvent être supprimés en toute sécurité, tels que les fichiers temporaires, les fichiers de cache, les fichiers de journalisation, et plus encore. En utilisant DiskMaster, vous pouvez facilement libérer de l'espace sur votre disque dur et améliorer les performances de votre ordinateur." Background="#FFFEF9F9"/>
            <Button x:Name="explorer" Content="Explorer le fichier" Margin="20 10" HorizontalAlignment="Center" Height="30" Background="#FF7E7C80" Click="explorer_Click"/>
            <Separator Margin="10"/>
        </StackPanel>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Button Name="systemFiles" Content="Fichiers systeme" Margin="10 0" Background="#FF7E7C80" Click="systemFiles_Click"></Button>
            <Button x:Name="assistanceStockage" Grid.Column="1" Content="Assistance stockage" Margin="10 0" Background="#FF7E7C80" Click="assistanceStockage_Click" ></Button>
            <Label Name="date" Grid.Column="0" Grid.ColumnSpan="2"  Content="date du dernier nettoyage: 00/00/0000" VerticalAlignment="Bottom" Background="DeepSkyBlue"></Label>
            <Button Name="github" Grid.Column="1" Content="my GitHub" VerticalAlignment="Bottom" Visibility="Hidden" Click="github_Click" Panel.ZIndex="1"></Button>
        </Grid>
        <Grid Grid.Row="3" Background="#FFF0F0F0">
            <StackPanel Grid.Row="3" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Name="nettoyer" Content="Nettoyer" Margin="10" HorizontalAlignment="Center" Height="30" Background="White" Foreground="Black" Click="nettoyer_Click"></Button>
                <Button x:Name="quitter" Content="Quitter" Margin="10" HorizontalAlignment="Center" Height="30" Background="White" Foreground="Black" Click="quitter_Click"></Button>
            </StackPanel>
        </Grid>

        

    </Grid>
</Window>
